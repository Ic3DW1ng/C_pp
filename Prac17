#include <iostream>

using namespace std;

int main() {
    // Очистка консоли
    system("cls"); 

    cout << "[ + ] Фигура: \"Крестик\"" << endl;

    int size;
    char texture;

    cout << "[ + ] Размер: ";
    cin >> size;
    cout << "[ + ] Текстура: ";
    cin >> texture;

    cout << "\n[ + ] Результат:\n" << endl;

    // Внешний цикл для строк (i)
    for (int i = 0; i < size; i++) {
        // Внутренний цикл для столбцов (j)
        for (int j = 0; j < size; j++) {
            
            // Проверка: главная диагональ ИЛИ побочная диагональ
            if (i == j || i + j == size - 1) {
                cout << texture << "     "; // Выводим текстуру
            } else {
                cout << ".     "; // Выводим пустоту
            }
        }
        cout << endl; // Переход на новую строку
    }

    return 0;
}
