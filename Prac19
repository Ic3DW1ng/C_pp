#include <iostream>
#include <cmath> // Для функции abs()

using namespace std;

int main() {
    // Очистка консоли
    system("cls"); 

    cout << "[ + ] Фигура: \"Ромб\"" << endl;

    int size;
    char texture;

    cout << "[ + ] Размер: ";
    cin >> size;
    cout << "[ + ] Текстура: ";
    cin >> texture;

    cout << "\n[ + ] Результат:\n" << endl;

    int mid = size / 2;

    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
            
            // Математическое условие пустого ромба:
            // Сумма расстояний от центра по i и по j должна быть равна радиусу (mid)
            if (abs(i - mid) + abs(j - mid) == mid) {
                cout << texture << "     ";
            } else {
                cout << ".     ";
            }
        }
        cout << endl;
    }

    return 0;
}
